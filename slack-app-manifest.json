{
    "_metadata": {
        "major_version": 2,
        "minor_version": 1
    },
    "display_information": {
        "name": "BrandSight Extractor",
        "description": "Alerts the #dev team when a ChatGPT extraction worker needs operator intervention (e.g. Cloudflare challenge).",
        "background_color": "#1a1a2e"
    },
    "features": {
        "bot_user": {
            "display_name": "BrandSight Extractor",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "chat:write",
                "chat:write.public"
            ]
        }
    },
    "settings": {
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "is_hosted": false,
        "token_rotation_enabled": false
    }
}
