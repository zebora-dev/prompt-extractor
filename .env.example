BRANDSIGHT_API_BASE_URL=https://hmwgplzdzffivawkflci.supabase.co/functions/v1/api
BRANDSIGHT_SUPABASE_URL=https://hmwgplzdzffivawkflci.supabase.co
BRANDSIGHT_SUPABASE_ANON_KEY=replace-with-anon-key-from-chromeApp-extension-shared-background-js
BRANDSIGHT_PROMPT_OUTPUTS_TABLE=prompts_outputs
BRANDSIGHT_PROMPT_OUTPUT_PRODUCTS_TABLE=prompts_outputs_products
BRANDSIGHT_PROMPT_OUTPUT_ENTITIES_TABLE=prompts_outputs_entities
BRANDSIGHT_SCORE_WORKFLOW_URL=https://workflow.zebora.io/api/workflows/score-single-output
WORKFLOW_API_KEY=
BRANDSIGHT_SCORE_WORKFLOW_FORCE_RUN=false
BRANDSIGHT_SCORE_WORKFLOW_SCORER_TYPES=

# Optional. Reuse a real browser profile so ChatGPT stays logged in between runs.
# Defaults to automated-extraction/.chrome-profile when unset.
# CHATGPT_CHROME_USER_DATA_DIR=/absolute/path/to/chrome-profile-for-automation

# Optional browser/runtime tuning.
CHATGPT_HEADLESS=false
CHATGPT_LOGIN_WAIT_SECONDS=180
CHATGPT_RESPONSE_TIMEOUT_SECONDS=300

# Automated ChatGPT login (opt-in). When false, the runner uses the manual
# Chrome-profile flow (CHATGPT_CHROME_USER_DATA_DIR) as before.
CHATGPT_AUTO_LOGIN=false
CHATGPT_LOGIN_EMAIL=
# Base64-encoded JSON. Decoded shape:
#   { "user@example.com": { "provider": "basic" | "google",
#                           "password": "...",
#                           "secret": { "chatgpt": "TOTP_BASE32_SECRET",
#                                       "google":  "TOTP_BASE32_SECRET" } } }
# Encode an accounts.json file with:
#   python -c "import base64,json,sys; print(base64.b64encode(json.dumps(json.load(sys.stdin)).encode()).decode())" < accounts.json
CHATGPT_ACCOUNTS_B64=

# Optional Prefect orchestration settings.
PREFECT_API_URL=http://localhost:4200/api
PREFECT_WORK_POOL=prompt-extraction-pool
